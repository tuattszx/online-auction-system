<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ComboBox?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import java.net.URL?>

<?import java.lang.*?>
<AnchorPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="auction.client.controllers.MainViewController">
   <stylesheets>
      <URL value="@../css/style.css" />
   </stylesheets>
   <children>
      <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" styleClass="navbar">
               <padding>
                  <Insets left="20" right="20" />
               </padding>
               <children>
                  <Label text="UET AUCTION" styleClass="logo-text" />

                  <Region prefWidth="10.0" />

                  <HBox alignment="CENTER" spacing="0" HBox.hgrow="ALWAYS" maxWidth="650.0">
                     <children>
                        <MenuButton fx:id="categoryMenu" text="Danh mục" styleClass="category-menu">
                           <items>
                              <MenuItem text="Bất động sản" />
                              <MenuItem text="Xe cộ" />
                              <MenuItem text="Đồ cổ &amp; Sưu tầm" />
                              <MenuItem text="Công nghệ" />
                           </items>
                        </MenuButton>

                        <TextField fx:id="txtsearch" promptText="Tìm kiếm sản phẩm đấu giá..." styleClass="search-field" HBox.hgrow="ALWAYS" />

                        <Button onAction="#onSearchAction" text="🔍" styleClass="search-button" />
                     </children>
                  </HBox>

                  <Region HBox.hgrow="ALWAYS" />

                  <VBox alignment="CENTER_RIGHT" spacing="2">
                     <Label text="Số dư khả dụng" styleClass="balance-label" />
                     <Label fx:id="lbbalance" text="1.000.000$" styleClass="balance-amount" />
                  </VBox>

                  <HBox alignment="CENTER" spacing="10" onMouseClicked="#onProfileClick" styleClass="profile-container">
                     <children>
                        <StackPane>
                           <Circle radius="20.0" fill="WHITE" stroke="#ddd" />
                           <ImageView fx:id="imgAvatar" fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                              <image>
                                 <Image url="@../img/people.jpg" />
                              </image>
                           </ImageView>
                        </StackPane>
                        <Label text="TViu" fx:id="lbusername" styleClass="username-text" />
                     </children>
                  </HBox>
               </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
               <padding>
                  <Insets left="30" right="30" />
               </padding>
               <children>
                  <Label text="Sắp xếp theo:" style="-fx-font-weight: bold; -fx-text-fill: #555;" />

                  <ComboBox fx:id="sortPrice" promptText="Giá tiền" styleClass="sort-combo"> </ComboBox>
                  <ComboBox fx:id="sortTime" promptText="Thời gian" styleClass="sort-combo"> </ComboBox>

                  <Region HBox.hgrow="ALWAYS" />

                  <Label text="Đang diễn ra: 10 sản phẩm" style="-fx-text-fill: #888; -fx-font-style: italic;" />
               </children>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: #f4f4f4;">
               <content>
                  <FlowPane fx:id="flitems"
                            alignment="CENTER"
                            hgap="25"
                            vgap="25"
                            style="-fx-padding: 30;">
                     <padding><Insets top="30" right="30" bottom="30" left="30" /></padding>
                     <children>

                        <fx:define>
                           <VBox fx:id="itemTemplate" alignment="CENTER" prefHeight="220.0" prefWidth="180.0" styleClass="auction-card">
                              <children>
                                 <ImageView fitHeight="120.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../img/images.jpg" /></image>
                                 </ImageView>
                                 <Label text="Anya Forger Limited" styleClass="item-name" />
                                 <Label text="Giá: 10.000.000$" styleClass="item-price" />
                                 <Button text="Đấu giá ngay" styleClass="bid-button-small" />
                              </children>
                           </VBox>
                        </fx:define>

                        <VBox onMouseClicked="#onItemClick" styleClass="auction-card" alignment="CENTER" prefHeight="220.0" prefWidth="180.0">
                           <ImageView fitHeight="120.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@../img/images.jpg" /></image></ImageView>
                           <Label text="Sản phẩm 1" styleClass="item-name" /><Label text="10.000.000$" styleClass="item-price" /><Button text="Đấu giá" styleClass="bid-button-small" />
                        </VBox>
                        <VBox onMouseClicked="#onItemClick" styleClass="auction-card" alignment="CENTER" prefHeight="220.0" prefWidth="180.0">
                           <ImageView fitHeight="120.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@../img/images.jpg" /></image></ImageView>
                           <Label text="Sản phẩm 2" styleClass="item-name" /><Label text="10.000.000$" styleClass="item-price" /><Button text="Đấu giá" styleClass="bid-button-small" />
                        </VBox>
                        <VBox onMouseClicked="#onItemClick" styleClass="auction-card" alignment="CENTER" prefHeight="220.0" prefWidth="180.0">
                           <ImageView fitHeight="120.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@../img/images.jpg" /></image></ImageView>
                           <Label text="Sản phẩm 3" styleClass="item-name" /><Label text="10.000.000$" styleClass="item-price" /><Button text="Đấu giá" styleClass="bid-button-small" />
                        </VBox>
                        <VBox onMouseClicked="#onItemClick" styleClass="auction-card" alignment="CENTER" prefHeight="220.0" prefWidth="180.0">
                           <ImageView fitHeight="120.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@../img/images.jpg" /></image></ImageView>
                           <Label text="Sản phẩm 4" styleClass="item-name" /><Label text="10.000.000$" styleClass="item-price" /><Button text="Đấu giá" styleClass="bid-button-small" />
                        </VBox>
                        <VBox onMouseClicked="#onItemClick" styleClass="auction-card" alignment="CENTER" prefHeight="220.0" prefWidth="180.0">
                           <ImageView fitHeight="120.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@../img/images.jpg" /></image></ImageView>
                           <Label text="Sản phẩm 5" styleClass="item-name" /><Label text="10.000.000$" styleClass="item-price" /><Button text="Đấu giá" styleClass="bid-button-small" />
                        </VBox>
                        <VBox onMouseClicked="#onItemClick" styleClass="auction-card" alignment="CENTER" prefHeight="220.0" prefWidth="180.0">
                           <ImageView fitHeight="120.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@../img/images.jpg" /></image></ImageView>
                           <Label text="Sản phẩm 6" styleClass="item-name" /><Label text="10.000.000$" styleClass="item-price" /><Button text="Đấu giá" styleClass="bid-button-small" />
                        </VBox>
                        <VBox onMouseClicked="#onItemClick" styleClass="auction-card" alignment="CENTER" prefHeight="220.0" prefWidth="180.0">
                           <ImageView fitHeight="120.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@../img/images.jpg" /></image></ImageView>
                           <Label text="Sản phẩm 7" styleClass="item-name" /><Label text="10.000.000$" styleClass="item-price" /><Button text="Đấu giá" styleClass="bid-button-small" />
                        </VBox>
                        <VBox onMouseClicked="#onItemClick" styleClass="auction-card" alignment="CENTER" prefHeight="220.0" prefWidth="180.0">
                           <ImageView fitHeight="120.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@../img/images.jpg" /></image></ImageView>
                           <Label text="Sản phẩm 8" styleClass="item-name" /><Label text="10.000.000$" styleClass="item-price" /><Button text="Đấu giá" styleClass="bid-button-small" />
                        </VBox>
                        <VBox onMouseClicked="#onItemClick" styleClass="auction-card" alignment="CENTER" prefHeight="220.0" prefWidth="180.0">
                           <ImageView fitHeight="120.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@../img/images.jpg" /></image></ImageView>
                           <Label text="Sản phẩm 9" styleClass="item-name" /><Label text="10.000.000$" styleClass="item-price" /><Button text="Đấu giá" styleClass="bid-button-small" />
                        </VBox>
                        <VBox onMouseClicked="#onItemClick" styleClass="auction-card" alignment="CENTER" prefHeight="220.0" prefWidth="180.0">
                           <ImageView fitHeight="120.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@../img/images.jpg" /></image></ImageView>
                           <Label text="Sản phẩm 10" styleClass="item-name" /><Label text="10.000.000$" styleClass="item-price" /><Button text="Đấu giá" styleClass="bid-button-small" />
                        </VBox>

                     </children>
                  </FlowPane>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</AnchorPane>