<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: pink;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="auction.client.controllers.LoginController">

   <stylesheets>
      <URL value="@../css/style.css" />
   </stylesheets>

   <children>
      <Label layoutX="187.0" layoutY="83.0" text="Tài khoản" />
      <Label layoutX="187.0" layoutY="126.0" prefHeight="17.0" prefWidth="51.0" text="Mật khẩu" />
      <TextField fx:id="txtUsername" alignment="CENTER" layoutX="256.0" layoutY="79.0" prefHeight="25.0" prefWidth="210.0" style="-fx-background-color: white;" styleClass="text-input" />
      <PasswordField fx:id="txtPassword" layoutX="256.0" layoutY="122.0" prefHeight="25.0" prefWidth="210.0" styleClass="text-input" />
      <Button fx:id="btnLogin" layoutX="302.0" layoutY="174.0" mnemonicParsing="false" onAction="#onLoginButtonClick" prefHeight="25.0" prefWidth="118.0" text="Đăng nhập" />
      <Label layoutX="293.0" layoutY="251.0" textFill="#706c6c">
         <font>
            <Font size="15.0" />
         </font>
      </Label>
      <Button fx:id="btnSignUp" layoutX="302.0" layoutY="272.0" mnemonicParsing="false" onAction="#onSignUpClick" prefHeight="25.0" prefWidth="118.0" text="Đăng ký" />

      <Button fx:id="btnForgotPassword" layoutX="302.0" layoutY="223.0" mnemonicParsing="false" prefHeight="27.0" prefWidth="118.0" styleClass="forgot-btn" text="Quên mật khẩu" />
   </children>
</AnchorPane>
