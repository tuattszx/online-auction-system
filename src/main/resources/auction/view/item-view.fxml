<AnchorPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="auction.client.controllers.ItemviewController">
   <children>
      <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="20.0" style="-fx-background-color: #ffffff; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
               <padding><Insets left="20.0" right="20.0" /></padding>
               <children>
                  <ImageView  fitHeight="40.0" fitWidth="80.0" onMouseClicked="#OnMouseBacktoMain" pickOnBounds="true" preserveRatio="true">
                     <image><Image url="@../img/logo-uet.jpg" /></image>
                  </ImageView>
                  <TextField fx:id="txtsearch" maxWidth="400.0" promptText="Tìm kiếm sản phẩm..." style="-fx-background-radius: 20;" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </top>

         <center>
            <GridPane hgap="10.0" style="-fx-padding: 10; -fx-background-color: #f4f4f4;" vgap="10.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="50.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="50.0" />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints minHeight="10.0" percentHeight="55.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" percentHeight="45.0" vgrow="SOMETIMES" />
               </rowConstraints>

               <children>
                  <StackPane prefHeight="333.0" prefWidth="471.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);" GridPane.columnIndex="0" GridPane.rowIndex="0">
                     <children>
                        <ImageView fx:id="itemImg" fitHeight="325.0" fitWidth="327.0" pickOnBounds="true" preserveRatio="true">
                           <image><Image url="@../img/images.jpg" /></image>
                        </ImageView>
                     </children>
                  </StackPane>

                  <VBox prefHeight="356.0" prefWidth="485.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                     <children>
                        <Label fx:id="itemName" style="-fx-font-size: 24; -fx-font-weight: bold;" text="SpyxFamily - Anya Forger" />
                        <Label text="Giá hiện tại:" textFill="#777" />
                        <Label fx:id="lbprice" style="-fx-font-size: 30; -fx-text-fill: #d32f2f; -fx-font-weight: bold;" text="1.000.000 $" />
                        <Separator />
                        <HBox spacing="10.0">
                           <children>
                              <Button fx:id="btprice1" maxWidth="Infinity" text="+ 50k" HBox.hgrow="ALWAYS" />
                              <Button fx:id="btprice2" maxWidth="Infinity" text="+ 100k" HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>
                        <TextField prefHeight="40.0" promptText="Nhập giá của bạn..." />
                        <Button maxWidth="Infinity" prefHeight="50.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold;" text="ĐẶT CƯỢC NGAY" />
                     </children>
                  </VBox>

                  <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;" GridPane.columnIndex="0" GridPane.rowIndex="1">
                     <children>
                        <HBox spacing="10.0">
                           <children>
                              <Button style="-fx-background-color: #eee;" text="Thông tin sản phẩm" />
                              <Button style="-fx-background-color: #eee;" text="Biểu đồ giá" />
                              <Button style="-fx-background-color: #eee;" text="Lịch sử cược" />
                           </children>
                        </HBox>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                           <content>
                              <Label fx:id="lbDescription" text="Mô tả chi tiết sản phẩm sẽ hiện ở đây..." wrapText="true" />
                           </content>
                        </ScrollPane>
                     </children>
                  </VBox>

                  <VBox prefHeight="262.0" prefWidth="470.0" spacing="10.0" style="-fx-background-color: #2c3e50; -fx-padding: 15; -fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Hoạt động gần đây" textFill="WHITE" />
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: #34495e;" vbarPolicy="NEVER" VBox.vgrow="ALWAYS">
                           <content>
                              <VBox prefHeight="255.0" prefWidth="452.0" spacing="5.0">
