                                    <Label layoutX="10.0" layoutY="10.0" text="[14:02:10] Người dùng A đã đặt 1.100.000 $" textFill="#ecf0f1" />
                                    <Label layoutX="10.0" layoutY="33.0" text="[14:05:33] Hệ thống: Còn lại 2 phút" textFill="#f1c40f" />
                                    <Label layoutX="10.0" layoutY="55.0" text="[14:05:33] Hệ thống: Còn lại 2 phút" textFill="#f1c40f" />
                                    <Label layoutX="10.0" layoutY="10.0" text="[14:02:10] Người dùng A đã đặt 1.100.000 $" textFill="#ecf0f1" />
                                    <Label layoutX="10.0" layoutY="33.0" text="[14:05:33] Hệ thống: Còn lại 2 phút" textFill="#f1c40f" />
                                    <Label layoutX="10.0" layoutY="55.0" text="[14:05:33] Hệ thống: Còn lại 2 phút" textFill="#f1c40f" />
                                    <Label layoutX="10.0" layoutY="78.0" text="[14:02:10] Người dùng A đã đặt 1.100.000 $" textFill="#ecf0f1" />
                                    <Label layoutX="10.0" layoutY="101.0" text="[14:05:33] Hệ thống: Còn lại 2 phút" textFill="#f1c40f" />
                                    <Label layoutX="10.0" layoutY="123.0" text="[14:05:33] Hệ thống: Còn lại 2 phút" textFill="#f1c40f" />
                                 </children>
                              </VBox>
                           </content>
                        </ScrollPane>
                     </children>
                  </VBox>
               </children>
            </GridPane>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
