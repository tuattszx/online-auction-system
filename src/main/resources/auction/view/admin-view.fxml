<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Line?>

<BorderPane prefHeight="750.0" prefWidth="1200.0"
            style="-fx-background-color: linear-gradient(to bottom right, #0f2027, #203a43, #2b5268);"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="auction.client.controllers.AdminController">

    <left>
        <VBox prefWidth="260.0" spacing="10.0" style="-fx-background-color: rgba(0, 0, 0, 0.4); -fx-background-radius: 0 30 30 0;">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="30.0" />
            </padding>
            <children>
                <Label text="ADMIN PANEL" textFill="#00d2ff">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" left="10.0" />
                    </VBox.margin>
                </Label>

                <Line endX="180.0" stroke="rgba(255,255,255,0.2)" />

                <Button fx:id="btnBack" alignment="BASELINE_LEFT" mnemonicParsing="false"
                        onAction="#handleBackToMain" prefHeight="45.0" prefWidth="230.0"
                        styleClass="back-button" text="← Quay lại Hệ thống">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="20.0" top="10.0" />
                    </VBox.margin>
                </Button>

                <Button fx:id="btnDashboard" alignment="BASELINE_LEFT" mnemonicParsing="false"
                        onAction="#handleShowDashboard" prefHeight="50.0" prefWidth="230.0"
                        styleClass="admin-menu-btn-active" text="📊 Tổng quan" />

                <Button fx:id="btnManageUsers" alignment="BASELINE_LEFT" mnemonicParsing="false"
                        onAction="#handleManageUsers" prefHeight="50.0" prefWidth="230.0"
                        styleClass="admin-menu-btn" text="👥 Quản lý Người dùng" />

                <Button fx:id="btnApproveItems" alignment="BASELINE_LEFT" mnemonicParsing="false"
                        onAction="#handleApproveItems" prefHeight="50.0" prefWidth="230.0"
                        styleClass="admin-menu-btn" text="📦 Phê duyệt Sản phẩm" />

                <Button fx:id="btnManageAuctions" alignment="BASELINE_LEFT" mnemonicParsing="false"
                        onAction="#handleManageAuctions" prefHeight="50.0" prefWidth="230.0"
                        styleClass="admin-menu-btn" text="🔨 Quản lý Đấu giá" />

                <Button fx:id="btnTransactionHistory" alignment="BASELINE_LEFT" mnemonicParsing="false"
                        onAction="#handleTransactionHistory" prefHeight="50.0" prefWidth="230.0"
                        styleClass="admin-menu-btn" text="📜 Lịch sử Giao dịch" />

                <Button fx:id="btnSettings" alignment="BASELINE_LEFT" mnemonicParsing="false"
                        onAction="#handleSettings" prefHeight="50.0" prefWidth="230.0"
                        styleClass="admin-menu-btn" text="⚙️ Cài đặt hệ thống" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="25.0">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <VBox>
                            <children>
                                <Label text="Quản lý tài khoản" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                                <Label text="Danh sách người dùng và trạng thái hoạt động" textFill="#bdc3c7" />
                            </children>
                        </VBox>
                        <HBox HBox.hgrow="ALWAYS" />
                        <TextField fx:id="txtSearch" prefHeight="40.0" prefWidth="280.0"
                                   promptText="Tìm người dùng..." styleClass="admin-search-field" />
                    </children>
                </HBox>

                <TableView fx:id="adminTable" prefHeight="500.0" styleClass="admin-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                        <TableColumn fx:id="colUsername" prefWidth="150.0" text="Tên đăng nhập" />
                        <TableColumn fx:id="colFullName" prefWidth="200.0" text="Họ và Tên" />
                        <TableColumn fx:id="colRole" prefWidth="120.0" text="Số dư" />
                        <TableColumn fx:id="colStatus" prefWidth="150.0" text="Trạng thái" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="20.0">
                    <children>
                        <Button fx:id="btnApproveSeller" mnemonicParsing="false"
                                onAction="#handleApproveSeller" prefHeight="45.0" prefWidth="180.0"
                                styleClass="btn-approve" text="Phê duyệt Seller" />
                        <Button fx:id="btnLockAccount" mnemonicParsing="false"
                                onAction="#handleLockAccount" prefHeight="45.0" prefWidth="180.0"
                                styleClass="btn-lock" text="Khóa tài khoản" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>