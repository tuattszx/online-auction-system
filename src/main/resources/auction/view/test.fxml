<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 10 20;">
            <Label text="DASHBOARD" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="18.0" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="15" alignment="CENTER">
                <Button text="Home" style="-fx-background-color: transparent; -fx-text-fill: white;" />
                <Button text="Settings" style="-fx-background-color: transparent; -fx-text-fill: white;" />
                <Circle fill="#ecf0f1" radius="15.0" />
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="200" spacing="10" style="-fx-background-color: #34495e; -fx-padding: 20 10;">
            <Button maxWidth="Infinity" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" text="📦 Products" />
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-alignment: CENTER_LEFT;" text="📊 Analytics" />
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-alignment: CENTER_LEFT;" text="👥 Customers" />
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-alignment: CENTER_LEFT;" text="⚙️ Configuration" />
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f4f4f4;">
            <VBox spacing="20" style="-fx-padding: 30;">
                <Label text="Create New Product">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>

                <GridPane hgap="15" vgap="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50" />
                        <ColumnConstraints percentWidth="50" />
                    </columnConstraints>

                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Title" />
                        <TextField promptText="Product Name" />
                    </VBox>
                    <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Category" />
                        <ComboBox maxWidth="Infinity" promptText="Select Category" />
                    </VBox>

                    <HBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Height" />
                            <TextField promptText="cm" />
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Length" />
                            <TextField promptText="cm" />
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Width" />
                            <TextField promptText="cm" />
                        </VBox>
                    </HBox>

                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <Label text="Weight" />
                        <TextField promptText="kg" />
                    </VBox>
                    <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <Label text="Price" />
                        <TextField promptText="\$0.00" />
                    </VBox>

                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2">
                        <Label text="Description" />
                        <TextArea prefHeight="100" promptText="Enter product details..." wrapText="true" />
                    </VBox>

                    <VBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="2" alignment="CENTER" style="-fx-border-color: #bdc3c7; -fx-border-style: dashed; -fx-border-width: 2; -fx-border-radius: 5; -fx-padding: 20;">
                        <Label text="Drag and drop design file here or" textFill="#7f8c8d" />
                        <Button text="Browse Files" style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7;" />
                    </VBox>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button prefWidth="100" text="Cancel" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" />
                    <Button prefWidth="100" text="Save" style="-fx-background-color: #27ae60; -fx-text-fill: white;" />
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>